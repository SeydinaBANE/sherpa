# ─── Application ───────────────────────────────────────────────
SHERPA_ENV=local
SHERPA_LOG_LEVEL=INFO
SHERPA_API_HOST=127.0.0.1
SHERPA_API_PORT=8000

# ─── LLM (Anthropic Claude) ────────────────────────────────────
# Routing multi-modèle pour optimiser coût/latence.
SHERPA_ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
SHERPA_LLM_MODEL_CHEAP=claude-haiku-4-5
SHERPA_LLM_MODEL_STANDARD=claude-sonnet-4-6
SHERPA_LLM_MODEL_DEEP=claude-opus-4-8

# ─── Embeddings (Voyage AI) ────────────────────────────────────
SHERPA_VOYAGE_API_KEY=pa-xxxxxxxx
SHERPA_EMBEDDING_MODEL=voyage-3

# ─── Vector store (Qdrant) ─────────────────────────────────────
SHERPA_QDRANT_URL=http://localhost:6333
SHERPA_QDRANT_COLLECTION=sherpa_chunks

# ─── Relational DB (Postgres) ──────────────────────────────────
SHERPA_DATABASE_URL=postgresql+psycopg://sherpa:sherpa@localhost:5432/sherpa

# ─── Cache (Redis) ─────────────────────────────────────────────
SHERPA_REDIS_URL=redis://localhost:6379/0

# ─── Observability (Langfuse) ──────────────────────────────────
SHERPA_LANGFUSE_PUBLIC_KEY=
SHERPA_LANGFUSE_SECRET_KEY=
SHERPA_LANGFUSE_HOST=http://localhost:3000

# ─── Cost guardrails ───────────────────────────────────────────
SHERPA_MAX_TOKENS_PER_REQUEST=4096
SHERPA_DAILY_TOKEN_BUDGET=1000000
