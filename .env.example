# ─── Application ───────────────────────────────────────────────
SHERPA_ENV=local
SHERPA_LOG_LEVEL=INFO
SHERPA_API_HOST=127.0.0.1
SHERPA_API_PORT=8000

# ─── Sécurité (off par défaut ; activer en prod) ───────────────
SHERPA_AUTH_ENABLED=false
SHERPA_API_KEYS=
SHERPA_RATE_LIMIT_ENABLED=false
SHERPA_RATE_LIMIT_REQUESTS=60
SHERPA_RATE_LIMIT_WINDOW_SECONDS=60
SHERPA_QUOTA_ENABLED=false
SHERPA_DAILY_REQUEST_QUOTA=1000

# ─── Backends (memory/echo par défaut → hybrid/anthropic en prod) ──
SHERPA_RETRIEVAL_BACKEND=memory
SHERPA_LLM_BACKEND=echo
SHERPA_MEMORY_BACKEND=memory
SHERPA_CACHE_BACKEND=memory
SHERPA_RRF_K=60
SHERPA_TOP_K=4

# ─── LLM (Anthropic Claude) ────────────────────────────────────
# Routing multi-modèle pour optimiser coût/latence.
SHERPA_ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
SHERPA_LLM_MODEL_CHEAP=claude-haiku-4-5
SHERPA_LLM_MODEL_STANDARD=claude-sonnet-4-6
SHERPA_LLM_MODEL_DEEP=claude-opus-4-8

# ─── Embeddings (Voyage AI) ────────────────────────────────────
SHERPA_VOYAGE_API_KEY=pa-xxxxxxxx
SHERPA_EMBEDDING_MODEL=voyage-3

# ─── Vector store (Qdrant) ─────────────────────────────────────
SHERPA_QDRANT_URL=http://localhost:6333
SHERPA_QDRANT_COLLECTION=sherpa_chunks

# ─── Relational DB (Postgres) ──────────────────────────────────
SHERPA_DATABASE_URL=postgresql+psycopg://sherpa:sherpa@localhost:5432/sherpa

# ─── Cache (Redis) ─────────────────────────────────────────────
SHERPA_REDIS_URL=redis://localhost:6379/0

# ─── Observability (Langfuse) ──────────────────────────────────
SHERPA_LANGFUSE_PUBLIC_KEY=
SHERPA_LANGFUSE_SECRET_KEY=
SHERPA_LANGFUSE_HOST=http://localhost:3000

# ─── Cache (LLM + embeddings) ──────────────────────────────────
SHERPA_LLM_CACHE_ENABLED=true
SHERPA_LLM_CACHE_TTL_SECONDS=3600
SHERPA_EMBEDDING_CACHE_ENABLED=true
SHERPA_EMBEDDING_CACHE_TTL_SECONDS=86400

# ─── Cost guardrails ───────────────────────────────────────────
SHERPA_MAX_TOKENS_PER_REQUEST=4096
SHERPA_DAILY_TOKEN_BUDGET=1000000

# ─── Résilience LLM (backend anthropic) ────────────────────────
SHERPA_LLM_MAX_RETRIES=3
SHERPA_LLM_RETRY_BASE_DELAY=0.2
SHERPA_LLM_TIMEOUT_SECONDS=30
SHERPA_BREAKER_FAILURE_THRESHOLD=5
SHERPA_BREAKER_RESET_TIMEOUT=30
